# World App Developer Portal App ID
# Get yours at: https://developer.worldcoin.org
NEXT_PUBLIC_APP_ID=app_staging_placeholder

# App URL (set to your ngrok URL when testing in World App)
NEXTAUTH_URL=http://localhost:3000

# ── Nonce signing ─────────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -hex 32
# NONCE_SECRET=

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# All chains fall back to free public nodes if these are unset.
# For MVP, set at least WORLD_CHAIN and ETHEREUM to paid Alchemy/Infura endpoints
# to avoid rate-limit-induced $0 balance reads under load.
#
# Alchemy: https://dashboard.alchemy.com  (free tier: 300M CUs/month)
# Infura:  https://app.infura.io           (free tier: 100k req/day)
# QuickNode: https://www.quicknode.com
#
# NEXT_PUBLIC_RPC_WORLD_CHAIN=https://worldchain-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_BNB=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_AVALANCHE=https://avax-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_SOLANA=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
# NEXT_PUBLIC_RPC_HYPEREVM=https://rpc.hyperliquid.xyz/evm

# ── Feature flags ─────────────────────────────────────────────────────────────
# Solana bridge routes are off by default until route quality is confirmed.
# Set to "true" to re-enable for testing.
# NEXT_PUBLIC_SOLANA_BRIDGE_ENABLED=false
